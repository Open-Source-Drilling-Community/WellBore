@page "/WellBoreSurveyRuns"
@inject ILogger<WellBoreSurveyRuns> logger
@inject ISnackbar Snackbar
@inject IWellBoreAPIUtils Api
@using System.Net.Http.Json
@using System.Text.Json
@using WellBoreModelShared = NORCE.Drilling.WellBore.ModelShared

<MudUnitAndReferenceChoiceTag HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="@DataUtils.UpdateDepthReferenceName"
                              GroundMudLineDepthReferenceSource="@groundMudLineDepthSource"
                              SeaWaterLevelDepthReferenceSource="@topWaterDepthSource"
                              WellHeadDepthReferenceSource="@wellHeadDepthSource"
                              RotaryTableDepthReferenceSource="@rotaryTableDepthSource">
    @if (fieldList == null || clusterList == null || wellList == null || wellBoreList == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <MudStack Spacing="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudGrid>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.h5">WellBore Survey Runs</MudText>
                        <MudText Typo="Typo.body2">All survey runs for the selected wellbore, shown in 3D and as a horizontal projection.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="2">
                        <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                            @foreach (WellBoreModelShared.Field field in AvailableFields)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="2">
                        <MudSelect Label="Cluster" T="Guid?" Value="@selectedClusterId" ValueChanged="OnClusterChanged" ShrinkLabel Clearable="true" Disabled="@(selectedFieldId == null || AvailableClusters.Count == 0)">
                            @foreach (WellBoreModelShared.Cluster cluster in AvailableClusters)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">@cluster.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="2">
                        <MudSelect Label="Well" T="Guid?" Value="@selectedWellId" ValueChanged="OnWellChanged" ShrinkLabel Clearable="true" Disabled="@(selectedFieldId == null || AvailableWells.Count == 0)">
                            @foreach (WellBoreModelShared.Well well in AvailableWells)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">@well.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="2">
                        <MudSelect Label="Wellbore" T="Guid?" Value="@selectedWellBoreId" ValueChanged="OnWellBoreChanged" ShrinkLabel Clearable="true" Disabled="@(selectedWellId == null || AvailableWellBores.Count == 0)">
                            @foreach (WellBoreModelShared.WellBore wellBore in AvailableWellBores)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)wellBore.MetaInfo.ID)">@wellBore.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="ReloadSelectedWellBoreAsync" Disabled="@(selectedWellBoreId == null)">Reload</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudSelect Label="Type" T="string" Value="@selectedSurveyRunTypeFilter" ValueChanged="OnSurveyRunFilterChanged" ShrinkLabel>
                            <MudSelectItem T="string" Value="@SurveyRunTypeFilterAll">All</MudSelectItem>
                            <MudSelectItem T="string" Value="@SurveyRunTypeFilterPlanned">Planned</MudSelectItem>
                            <MudSelectItem T="string" Value="@SurveyRunTypeFilterActual">Actual</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                <MudDivider Class="my-3" />
                <MudGrid>
                    <MudItem xs="12" sm="4" md="3">
                        <MudNumericField @bind-Value="ellipseConfidenceFactor" Label="Confidence factor" Min="0.0" Max="1.0" Step="0.01" ShrinkLabel />
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" OnClick="CalculateUncertaintyEllipsesAsync" Disabled="@(surveyRunList.Count == 0 || isLoadingSurveyRuns || isCalculatingEllipses)">Calculate Ellipses</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" FullWidth="true" OnClick="ClearUncertaintyEllipses" Disabled="@(ellipseResultsBySurveyRun.Count == 0 || isCalculatingEllipses)">Clear Ellipses</MudButton>
                    </MudItem>
                    @if (isCalculatingEllipses)
                    {
                        <MudItem xs="12" md="3">
                            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mt-4" />
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@errorMessage</MudAlert>
            }
            else if (isLoadingSurveyRuns)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Loading survey runs for the selected wellbore.</MudAlert>
            }
            else if (selectedFieldId == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Select a field to display its wellbores.</MudAlert>
            }
            else if (selectedWellId == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Select a well to display its wellbores.</MudAlert>
            }
            else if (AvailableWellBores.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No wellbores were found for the selected filters.</MudAlert>
            }
            else if (selectedWellBoreId == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Select a wellbore to display its survey runs.</MudAlert>
            }
            else if (surveyRunList.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No survey runs were found for the selected wellbore.</MudAlert>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">3D View</MudText>
                            <Scatter3DPlot XUnit="PositionDrilling" YUnit="PositionDrilling" ZUnit="DepthDrilling"
                                           NameList="@Plot3DNames" ModeFlagList="@Plot3DModeFlags" ColorList="@Plot3DColors"
                                           XValuesList="@Plot3DEastValuesList" YValuesList="@Plot3DNorthValuesList" ZValuesList="@Plot3DTvdValuesList"
                                           XAxisTitle="Easting" YAxisTitle="Northing" ZAxisTitle="TVD"
                                           PlotTitle="Wellbore survey runs" PlotHeight="600" ZAxisReversed="true"
                                           XDrillingSignalReference="@DrillingSignalReferenceType.Position"
                                           YDrillingSignalReference="@DrillingSignalReferenceType.Position"
                                           ZDrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                           PositionDirectionX="@PositionDirectionType.East"
                                           PositionDirectionY="@PositionDirectionType.North"
                                           ShowLegends="@Plot3DShowLegends" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">Horizontal Projection</MudText>
                            <ScatterPlot XUnit="PositionDrilling" YUnit="PositionDrilling"
                                         NameList="@PlotHorizontalNames" ModeFlagList="@PlotHorizontalModeFlags" ColorList="@PlotHorizontalColors"
                                         XValuesList="@PlotHorizontalEastValuesList" YValuesList="@PlotHorizontalNorthValuesList"
                                         XAxisTitle="Easting" YAxisTitle="Northing"
                                         PlotTitle="Horizontal projection" PlotHeight="600" AspectRatio="1"
                                         XDrillingSignalReference="@DrillingSignalReferenceType.Position"
                                         YDrillingSignalReference="@DrillingSignalReferenceType.Position"
                                         PositionDirectionX="@PositionDirectionType.East"
                                         PositionDirectionY="@PositionDirectionType.North"
                                           ShowLegends="@PlotHorizontalShowLegends" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">Legend</MudText>
                    <MudGrid>
                        @foreach (var trace in plotTraces.Where(trace => trace.ShowLegend))
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <span style="@($"width:18px;height:18px;border-radius:50%;display:inline-block;background:{trace.Color};")"></span>
                                    <MudText Typo="Typo.body2">@trace.Name</MudText>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }
        </MudStack>
    }
</MudUnitAndReferenceChoiceTag>

@code {
    private List<WellBoreModelShared.Field>? fieldList;
    private List<WellBoreModelShared.Cluster>? clusterList;
    private List<WellBoreModelShared.Well>? wellList;
    private List<WellBoreModelShared.WellBore>? wellBoreList;
    private List<WellBoreModelShared.SurveyRunLight> surveyRunLightList = [];
    private List<WellBoreModelShared.SurveyRun> surveyRunList = [];
    private Guid? selectedFieldId;
    private Guid? selectedClusterId;
    private Guid? selectedWellId;
    private Guid? selectedWellBoreId;
    private string? errorMessage;
    private bool isLoadingSurveyRuns;
    private const string SurveyRunTypeFilterAll = "All";
    private const string SurveyRunTypeFilterPlanned = "Planned";
    private const string SurveyRunTypeFilterActual = "Actual";
    private string selectedSurveyRunTypeFilter = SurveyRunTypeFilterAll;
    private bool isCalculatingEllipses;
    private double ellipseConfidenceFactor = 0.95;
    private List<PlotTrace> plotTraces = [];
    private Dictionary<Guid, List<WellBoreModelShared.SurveyStationEllipseResult>> ellipseResultsBySurveyRun = [];

    private GroundMudLineDepthReferenceSource groundMudLineDepthSource = new();
    private SeaWaterLevelDepthReferenceSource topWaterDepthSource = new();
    private WellHeadDepthReferenceSource wellHeadDepthSource = new();
    private RotaryTableDepthReferenceSource rotaryTableDepthSource = new();

    private List<string> PlotNames => plotTraces.Select(trace => trace.Name).ToList();
    private List<int> PlotModeFlags => plotTraces.Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotColors => plotTraces.Select(trace => trace.Color).ToList();
    private List<bool> PlotShowLegends => plotTraces.Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> NorthValuesList => plotTraces.Select(trace => trace.NorthValues).ToList();
    private List<List<object>> EastValuesList => plotTraces.Select(trace => trace.EastValues).ToList();
    private List<List<object>> TvdValuesList => plotTraces.Select(trace => trace.TvdValues).ToList();
    private List<string> Plot3DNames => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.Name).ToList();
    private List<int> Plot3DModeFlags => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ModeFlag).ToList();
    private List<string> Plot3DColors => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.Color).ToList();
    private List<bool> Plot3DShowLegends => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> Plot3DNorthValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.NorthValues).ToList();
    private List<List<object>> Plot3DEastValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.EastValues).ToList();
    private List<List<object>> Plot3DTvdValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.TvdValues).ToList();
    private List<string> PlotHorizontalNames => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.Name).ToList();
    private List<int> PlotHorizontalModeFlags => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotHorizontalColors => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.Color).ToList();
    private List<bool> PlotHorizontalShowLegends => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> PlotHorizontalNorthValuesList => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.NorthValues).ToList();
    private List<List<object>> PlotHorizontalEastValuesList => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.EastValues).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            logger.LogInformation("Trying to load list of Fields, Clusters, Wells and WellBores");
            Task<ICollection<WellBoreModelShared.Field>> fieldTask = Api.ClientField.GetAllFieldAsync();
            Task<ICollection<WellBoreModelShared.Cluster>> clusterTask = Api.ClientCluster.GetAllClusterAsync();
            Task<ICollection<WellBoreModelShared.Well>> wellTask = Api.ClientWell.GetAllWellAsync();
            Task<ICollection<WellBoreModelShared.WellBore>> wellBoreTask = Api.ClientWellBore.GetAllWellBoreAsync();
            await Task.WhenAll(fieldTask, clusterTask, wellTask, wellBoreTask);

            fieldList = fieldTask.Result.Where(x => x?.MetaInfo != null).OrderBy(x => x.Name).ToList();
            clusterList = clusterTask.Result.Where(x => x?.MetaInfo != null).OrderBy(x => x.Name).ToList();
            wellList = wellTask.Result.Where(x => x?.MetaInfo != null).OrderBy(x => x.Name).ToList();
            wellBoreList = wellBoreTask.Result.Where(x => x?.MetaInfo != null).OrderBy(x => x.Name).ToList();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading fields, clusters, wells and wellbores");
            errorMessage = "Unable to load fields, clusters, wells and wellbores.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading fields, clusters, wells and wellbores");
            errorMessage = "Unable to load fields, clusters, wells and wellbores.";
            Snackbar.Add(errorMessage, Severity.Error);
        }

        await InvokeAsync(StateHasChanged);
    }

    private List<WellBoreModelShared.Field> AvailableFields => fieldList?.Where(x => x?.MetaInfo != null).OrderBy(x => x.Name).ToList() ?? [];

    private List<WellBoreModelShared.Cluster> AvailableClusters =>
        clusterList?.Where(x => x?.MetaInfo != null && x.FieldID == selectedFieldId && !x.IsSingleWell).OrderBy(x => x.Name).ToList() ?? [];

    private List<WellBoreModelShared.Well> AvailableWells =>
        wellList?.Where(well => MatchesSelectedField(well) && MatchesSelectedCluster(well)).OrderBy(well => well.Name).ToList() ?? [];

    private List<WellBoreModelShared.WellBore> AvailableWellBores =>
        wellBoreList?.Where(wb => selectedWellId != null && wb?.WellID == selectedWellId).OrderBy(wb => wb.Name).ToList() ?? [];

    private bool MatchesSelectedField(WellBoreModelShared.Well? well)
    {
        if (selectedFieldId == null || well?.ClusterID == null || clusterList == null) return false;
        WellBoreModelShared.Cluster? cluster = clusterList.FirstOrDefault(c => c?.MetaInfo?.ID == well.ClusterID);
        return cluster?.FieldID == selectedFieldId;
    }

    private bool MatchesSelectedCluster(WellBoreModelShared.Well? well)
    {
        if (selectedClusterId == null) return true;
        return well?.ClusterID == selectedClusterId;
    }

    private async Task OnFieldChanged(Guid? fieldId)
    {
        selectedFieldId = fieldId;
        selectedClusterId = null;
        selectedWellId = null;
        selectedWellBoreId = null;
        ResetViewState();
        UpdateSelectedClusterDepthReferenceSources(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnClusterChanged(Guid? clusterId)
    {
        selectedClusterId = clusterId;
        selectedWellId = null;
        selectedWellBoreId = null;
        ResetViewState();
        UpdateSelectedClusterDepthReferenceSources(clusterId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnWellChanged(Guid? wellId)
    {
        selectedWellId = wellId;
        selectedWellBoreId = null;
        ResetViewState();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnWellBoreChanged(Guid? wellBoreId)
    {
        selectedWellBoreId = wellBoreId;
        if (selectedFieldId is Guid fieldId && selectedWellId is Guid wellId && selectedWellBoreId is Guid selected)
        {
            await LoadSurveyRunsAsync(fieldId, selectedClusterId, wellId, selected);
        }
        else
        {
            ResetViewState();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadSelectedWellBoreAsync()
    {
        if (selectedFieldId is Guid fieldId && selectedWellId is Guid wellId && selectedWellBoreId is Guid wellBoreId)
        {
            await LoadSurveyRunsAsync(fieldId, selectedClusterId, wellId, wellBoreId);
        }
    }

    private void UpdateSelectedClusterDepthReferenceSources(Guid? clusterId)
    {
        groundMudLineDepthSource.GroundMudLineDepthReference = null;
        topWaterDepthSource.SeaWaterLevelDepthReference = null;
        wellHeadDepthSource.WellHeadDepthReference = null;
        rotaryTableDepthSource.RotaryTableDepthReference = null;

        if (clusterId == null || clusterList == null)
        {
            return;
        }

        WellBoreModelShared.Cluster? selectedCluster = clusterList.FirstOrDefault(cluster => cluster.MetaInfo?.ID == clusterId);
        if (selectedCluster?.GroundMudLineDepth?.GaussianValue != null)
        {
            groundMudLineDepthSource.GroundMudLineDepthReference = selectedCluster.GroundMudLineDepth.GaussianValue.Mean;
        }
        if (selectedCluster?.TopWaterDepth?.GaussianValue != null)
        {
            topWaterDepthSource.SeaWaterLevelDepthReference = selectedCluster.TopWaterDepth.GaussianValue.Mean;
        }
        if (selectedCluster?.ReferenceDepth?.GaussianValue != null)
        {
            wellHeadDepthSource.WellHeadDepthReference = selectedCluster.ReferenceDepth.GaussianValue.Mean;
        }
    }

    private void ResetViewState()
    {
        surveyRunLightList.Clear();
        surveyRunList.Clear();
        ClearPlots();
        errorMessage = null;
    }


    private async Task OnSurveyRunFilterChanged(string value)
    {
        selectedSurveyRunTypeFilter = string.IsNullOrWhiteSpace(value) ? SurveyRunTypeFilterAll : value;
        await ReloadCurrentSelectionAsync();
    }

    private bool MatchesSurveyRunFilters(WellBoreModelShared.SurveyRunLight surveyRun)
    {
        bool typeMatches = selectedSurveyRunTypeFilter == SurveyRunTypeFilterAll ||
            string.Equals(surveyRun.SurveyRunType.ToString(), selectedSurveyRunTypeFilter, StringComparison.OrdinalIgnoreCase);
        return typeMatches;
    }

    private async Task ReloadCurrentSelectionAsync()
    {
        if (selectedFieldId is Guid fieldId && selectedWellId is Guid wellId && selectedWellBoreId is Guid wellBoreId) { await LoadSurveyRunsAsync(fieldId, selectedClusterId, wellId, wellBoreId); }
    }

    private async Task LoadSurveyRunsAsync(Guid fieldId, Guid? clusterId, Guid wellId, Guid wellBoreId)
    {
        try
        {
            errorMessage = null;
            isLoadingSurveyRuns = true;
            surveyRunLightList.Clear();
            surveyRunList.Clear();
            ClearPlots();
            await InvokeAsync(StateHasChanged);

            logger.LogInformation("Loading survey run light data for field {FieldId}, cluster {ClusterId}, well {WellId} and wellbore {WellBoreId}", fieldId, clusterId, wellId, wellBoreId);
            surveyRunLightList = (await Api.ClientTrajectory.GetAllSurveyRunLightAsync(fieldId: fieldId, clusterId: clusterId, wellId: wellId, wellBoreId: wellBoreId))
                .Where(t => t?.MetaInfo != null && t.MetaInfo.ID != Guid.Empty)
                .OrderBy(t => t.Name)
                .ToList();

            List<Task<WellBoreModelShared.SurveyRun>> detailTasks = surveyRunLightList
                .Select(light => LoadSurveyRunWithSurveyStationsAsync(light.MetaInfo.ID))
                .ToList();

            surveyRunList = (await Task.WhenAll(detailTasks))
                .Where(t => t != null)
                .OrderBy(t => t.Name)
                .ToList();

            UpdatePlots();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading survey runs for wellbore {WellBoreId}", wellBoreId);
            errorMessage = "Unable to load survey runs for the selected wellbore.";
            Snackbar.Add(errorMessage, Severity.Error);
            ResetViewState();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading survey runs for wellbore {WellBoreId}", wellBoreId);
            errorMessage = "Unable to load survey runs for the selected wellbore.";
            Snackbar.Add(errorMessage, Severity.Error);
            ResetViewState();
        }
        finally
        {
            isLoadingSurveyRuns = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<WellBoreModelShared.SurveyRun> LoadSurveyRunWithSurveyStationsAsync(Guid surveyRunId)
    {
        WellBoreModelShared.SurveyRun surveyRun = await Api.ClientTrajectory.GetSurveyRunByIdAsync(surveyRunId);
        int chunkCount = await Api.HttpClientTrajectory.GetFromJsonAsync<int>($"SurveyRun/{surveyRunId}/SurveyStations/ChunkCount");
        if (chunkCount <= 0)
        {
            surveyRun.SurveyStationList ??= [];
            return surveyRun;
        }

        List<WellBoreModelShared.SurveyStation> stations = [];
        for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
        {
            WellBoreModelShared.SurveyStationChunk? chunk = await Api.HttpClientTrajectory.GetFromJsonAsync<SurveyStationChunk>($"SurveyRun/{surveyRunId}/SurveyStations/Chunks/{chunkIndex}");
            if (chunk?.SurveyStationList is { Count: > 0 } chunkStations)
            {
                stations.AddRange(chunkStations);
            }
        }

        surveyRun.SurveyStationList = stations;
        return surveyRun;
    }

    private void UpdatePlots()
    {
        int colorIndex = 0;
        List<PlotTrace> nextPlotTraces = [];
        foreach (WellBoreModelShared.SurveyRun surveyRun in surveyRunList)
        {
            if (surveyRun?.SurveyStationList == null || surveyRun.SurveyStationList.Count == 0) continue;
            List<object> northValues = [];
            List<object> eastValues = [];
            List<object> tvdValues = [];
            foreach (WellBoreModelShared.SurveyStation station in surveyRun.SurveyStationList)
            {
                AppendPoint(station, northValues, eastValues, tvdValues);
            }
            if (northValues.Count < 2 || northValues.Count != eastValues.Count || northValues.Count != tvdValues.Count) continue;
            nextPlotTraces.Add(new PlotTrace(
                string.IsNullOrWhiteSpace(surveyRun.Name) ? "survey run" : surveyRun.Name,
                1,
                Colors[colorIndex % Colors.Length],
                true,
                northValues,
                eastValues,
                tvdValues));
            colorIndex++;
        }
        AddEllipseTracesForLoadedSurveyRuns(nextPlotTraces);
        plotTraces = nextPlotTraces;
    }


    private async Task CalculateUncertaintyEllipsesAsync()
    {
        if (surveyRunList.Count == 0)
        {
            return;
        }

        try
        {
            isCalculatingEllipses = true;
            ellipseResultsBySurveyRun.Clear();
            await InvokeAsync(StateHasChanged);

            foreach (WellBoreModelShared.SurveyRun surveyRun in surveyRunList)
            {
                if (surveyRun.MetaInfo?.ID is not Guid surveyRunId ||
                    surveyRun.SurveyStationList is not { Count: > 0 } surveyStations)
                {
                    continue;
                }

                WellBoreModelShared.SurveyStationEllipseCalculation order = new()
                {
                    MetaInfo = new WellBoreModelShared.MetaInfo { ID = Guid.NewGuid() },
                    Name = $"{surveyRun.Name} uncertainty ellipses",
                    Description = string.Empty,
                    CreationDate = DateTimeOffset.UtcNow,
                    LastModificationDate = DateTimeOffset.UtcNow,
                    ConfidenceFactor = ellipseConfidenceFactor,
                    SurveyStationList = surveyStations
                };

                HttpResponseMessage response = await Api.HttpClientTrajectory.PostAsJsonAsync("SurveyStationEllipseCalculation", order);
                response.EnsureSuccessStatusCode();
                WellBoreModelShared.SurveyStationEllipseCalculation? result = await response.Content.ReadFromJsonAsync<WellBoreModelShared.SurveyStationEllipseCalculation>();
                if (result?.SurveyStationEllipseResultList is { Count: > 0 } ellipseResults)
                {
                    ellipseResultsBySurveyRun[surveyRunId] = ellipseResults.ToList();
                }
            }

            UpdatePlots();
            if (ellipseResultsBySurveyRun.Count == 0)
            {
                Snackbar.Add("No uncertainty ellipses could be calculated.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while calculating uncertainty ellipses");
            Snackbar.Add("Problem while calculating uncertainty ellipses: " + ex.Message, Severity.Error);
        }
        finally
        {
            isCalculatingEllipses = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void ClearUncertaintyEllipses()
    {
        ellipseResultsBySurveyRun.Clear();
        UpdatePlots();
    }

    private void AddEllipseTracesForLoadedSurveyRuns(List<PlotTrace> traces)
    {
        int colorIndex = 0;
        foreach (WellBoreModelShared.SurveyRun surveyRun in surveyRunList)
        {
            if (surveyRun?.SurveyStationList == null || surveyRun.SurveyStationList.Count == 0)
            {
                continue;
            }

            List<object> northValues = [];
            List<object> eastValues = [];
            List<object> tvdValues = [];
            foreach (WellBoreModelShared.SurveyStation station in surveyRun.SurveyStationList)
            {
                AppendPoint(station, northValues, eastValues, tvdValues);
            }

            if (northValues.Count >= 2 && northValues.Count == eastValues.Count && northValues.Count == tvdValues.Count)
            {
                if (surveyRun.MetaInfo?.ID is Guid surveyRunId &&
                    ellipseResultsBySurveyRun.TryGetValue(surveyRunId, out var ellipseResults))
                {
                    AddEllipseTraces(traces, surveyRun.SurveyStationList, ellipseResults, Colors[colorIndex % Colors.Length], surveyRun.Name);
                }
                colorIndex++;
            }
        }
    }

    private static void AddEllipseTraces(
        List<PlotTrace> traces,
        ICollection<WellBoreModelShared.SurveyStation> surveyStations,
        IReadOnlyList<WellBoreModelShared.SurveyStationEllipseResult> ellipseResults,
        string color,
        string? surveyRunName)
    {
        bool horizontalLegendShown = false;
        bool perpendicularLegendShown = false;
        foreach ((WellBoreModelShared.SurveyStation station, WellBoreModelShared.SurveyStationEllipseResult result) in SelectEvenlySpacedEllipses(surveyStations, ellipseResults))
        {
            if (BuildHorizontalEllipseTrace(station, result.HorizontalEllipse, color, !horizontalLegendShown, surveyRunName) is { } horizontalTrace)
            {
                traces.Add(horizontalTrace);
                horizontalLegendShown = true;
            }
            if (BuildPerpendicularEllipseTrace(station, result.PerpendicularEllipse, color, !perpendicularLegendShown, surveyRunName) is { } perpendicularTrace)
            {
                traces.Add(perpendicularTrace);
                perpendicularLegendShown = true;
            }
        }
    }

    private static IReadOnlyList<(WellBoreModelShared.SurveyStation Station, WellBoreModelShared.SurveyStationEllipseResult Result)> SelectEvenlySpacedEllipses(
        ICollection<WellBoreModelShared.SurveyStation> surveyStations,
        IReadOnlyList<WellBoreModelShared.SurveyStationEllipseResult> ellipseResults)
    {
        List<(WellBoreModelShared.SurveyStation Station, WellBoreModelShared.SurveyStationEllipseResult Result)> candidates = [];
        foreach (WellBoreModelShared.SurveyStationEllipseResult result in ellipseResults)
        {
            WellBoreModelShared.SurveyStation? station = FindStation(surveyStations, result.MD);
            if (station != null)
            {
                candidates.Add((station, result));
            }
        }

        if (candidates.Count <= MaxDisplayedUncertaintyEllipses)
        {
            return candidates;
        }

        List<(WellBoreModelShared.SurveyStation Station, WellBoreModelShared.SurveyStationEllipseResult Result)> ordered = candidates
            .OrderBy(candidate => candidate.Result.MD ?? candidate.Station.MD ?? candidate.Station.Abscissa ?? double.MaxValue)
            .ToList();
        HashSet<int> selectedIndexes = [];
        for (int sampleIndex = 0; sampleIndex < MaxDisplayedUncertaintyEllipses; sampleIndex++)
        {
            int sourceIndex = (int)Math.Round(sampleIndex * (ordered.Count - 1.0) / (MaxDisplayedUncertaintyEllipses - 1.0));
            selectedIndexes.Add(Math.Clamp(sourceIndex, 0, ordered.Count - 1));
        }
        selectedIndexes.Add(ordered.Count - 1);
        return selectedIndexes.Order().Select(index => ordered[index]).ToList();
    }

    private static WellBoreModelShared.SurveyStation? FindStation(ICollection<WellBoreModelShared.SurveyStation> surveyStations, double? md)
    {
        if (md is not { } definedMd)
        {
            return null;
        }

        return surveyStations
            .Where(station => station != null && (station.MD ?? station.Abscissa) is { })
            .OrderBy(station => Math.Abs(((station.MD ?? station.Abscissa) ?? double.MaxValue) - definedMd))
            .FirstOrDefault();
    }

    private static PlotTrace? BuildHorizontalEllipseTrace(WellBoreModelShared.SurveyStation station, WellBoreModelShared.SurveyStationEllipse? ellipse, string color, bool showLegend, string? surveyRunName)
    {
        if (ellipse?.SemiMajorAxis is not double semiMajor ||
            ellipse.SemiMinorAxis is not double semiMinor ||
            ellipse.OrientationAngle is not double angle ||
            station.X is not double centerNorth ||
            station.Y is not double centerEast)
        {
            return null;
        }

        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        double centerTvd = station.TVD ?? station.Z ?? 0.0;
        for (int i = 0; i <= EllipsePointCount; i++)
        {
            double phi = 2.0 * Math.PI * i / EllipsePointCount;
            double major = semiMajor * Math.Cos(phi);
            double minor = semiMinor * Math.Sin(phi);
            double northOffset = major * Math.Cos(angle) - minor * Math.Sin(angle);
            double eastOffset = major * Math.Sin(angle) + minor * Math.Cos(angle);
            northValues.Add(centerNorth + northOffset);
            eastValues.Add(centerEast + eastOffset);
            tvdValues.Add(centerTvd);
        }

        return new PlotTrace($"{surveyRunName ?? "survey run"} horizontal ellipses", 1, color, showLegend, northValues, eastValues, tvdValues, false, true);
    }

    private static PlotTrace? BuildPerpendicularEllipseTrace(WellBoreModelShared.SurveyStation station, WellBoreModelShared.SurveyStationEllipse? ellipse, string color, bool showLegend, string? surveyRunName)
    {
        if (ellipse?.SemiMajorAxis is not double semiMajor ||
            ellipse.SemiMinorAxis is not double semiMinor ||
            ellipse.OrientationAngle is not double angle ||
            station.Inclination is not double inclination ||
            station.Azimuth is not double azimuth ||
            station.X is not double centerNorth ||
            station.Y is not double centerEast)
        {
            return null;
        }

        double centerTvd = station.TVD ?? station.Z ?? 0.0;
        double cosA = Math.Cos(azimuth);
        double sinA = Math.Sin(azimuth);
        double cosI = Math.Cos(inclination);
        double sinI = Math.Sin(inclination);
        double cosO = Math.Cos(angle);
        double sinO = Math.Sin(angle);
        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        for (int i = 0; i <= EllipsePointCount; i++)
        {
            double phi = 2.0 * Math.PI * i / EllipsePointCount;
            double localX0 = semiMajor * Math.Cos(phi);
            double localY0 = semiMinor * Math.Sin(phi);
            double localX = localX0 * cosO - localY0 * sinO;
            double localY = localX0 * sinO + localY0 * cosO;
            northValues.Add(centerNorth + cosA * cosI * localX - sinA * localY);
            eastValues.Add(centerEast + sinA * cosI * localX + cosA * localY);
            tvdValues.Add(centerTvd - sinI * localX);
        }

        return new PlotTrace($"{surveyRunName ?? "survey run"} perpendicular ellipses", 1, color, showLegend, northValues, eastValues, tvdValues, true, false);
    }

    private static void AppendPoint(WellBoreModelShared.SurveyStation? point, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (point?.X is not { } north || point.Y is not { } east) return;
        double tvd = point.TVD ?? point.Z ?? 0.0;
        AppendPointValues(north, east, tvd, northValues, eastValues, tvdValues);
    }

    private static void AppendPointValues(double north, double east, double tvd, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (northValues.Count > 0 &&
            eastValues.Count == northValues.Count &&
            tvdValues.Count == northValues.Count &&
            TryGetLastDouble(northValues, out double lastNorth) &&
            TryGetLastDouble(eastValues, out double lastEast) &&
            TryGetLastDouble(tvdValues, out double lastTvd) &&
            AreClose(lastNorth, north) &&
            AreClose(lastEast, east) &&
            AreClose(lastTvd, tvd))
        {
            return;
        }
        northValues.Add(north);
        eastValues.Add(east);
        tvdValues.Add(tvd);
    }

    private static bool TryGetLastDouble(List<object> values, out double value)
    {
        value = default;
        if (values.Count == 0) return false;
        object last = values[^1];
        return last switch
        {
            double d => (value = d) == d,
            float f => (value = f) == f,
            decimal m => (value = (double)m) == (double)m,
            int i => (value = i) == i,
            long l => (value = l) == l,
            _ => false
        };
    }

    private static bool AreClose(double left, double right) => Math.Abs(left - right) <= 1e-6;
    private void ClearPlots() => plotTraces = [];

    private static readonly string[] Colors =
    [
        "black","blue","grey","red","orange","green","yellow","pink","brown","purple"
    ];

    private sealed record PlotTrace(string Name, int ModeFlag, string Color, bool ShowLegend, List<object> NorthValues, List<object> EastValues, List<object> TvdValues,
        bool ShowIn3D = true,
        bool ShowInHorizontal = true);


    private const int MaxDisplayedUncertaintyEllipses = 200;
    private const int EllipsePointCount = 72;

}







